# Build output
/bin/
/dist/
*.exe
*.test
*.out
# Go leaves binaries matching the package's last-path element in CWD when
# `go build ./path/to/pkg` is run without -o. Catch common root-level cases:
/ebind
/cmd-*
/[0-9][0-9]-*

# Test + coverage
coverage.out
coverage.html
*.prof
*.bench

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Go
vendor/
go.work
go.work.sum

# Local tmp + data
/tmp/
*.log
/data/
/.nats/

# Plans & scratch (keep .claude/ for shared project config if ever tracked)
/.plans/
